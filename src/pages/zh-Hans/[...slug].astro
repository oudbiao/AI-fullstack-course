---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  const zhCnEntries = docs.filter((entry) => entry.id === "zh-cn" || entry.id.startsWith("zh-cn/"));
  const pathsBySlug = new Map();

  for (const entry of zhCnEntries) {
    let slug = entry.id.replace(/^zh-cn\/?/, "");
    if (slug === "index") slug = "";
    slug = slug.replace(/\/index$/, "");

    const target = slug ? `/zh-cn/${slug}/` : "/zh-cn/";

    pathsBySlug.set(slug, {
      params: { slug },
      props: { target },
    });
  }

  return [
    ...pathsBySlug.values(),
  ];
}

const { target } = Astro.props;
const canonical = new URL(target, Astro.site ?? "https://airoads.org").href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>Chinese course redirect | AI Roads</title>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={canonical} />
    <script is:inline define:vars={{ target }}>location.replace(target);</script>
  </head>
  <body>
    <p>Moved to <a href={target}>the Chinese course</a>.</p>
  </body>
</html>
